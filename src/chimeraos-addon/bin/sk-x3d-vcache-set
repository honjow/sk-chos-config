#!/bin/bash
# AMD X3D V-Cache mode switcher
# Switches the preferred CCD between "cache" (V-Cache) and "frequency" (high-clock)

X3D_MODE_PATH=$(find /sys/bus/platform/drivers/amd_x3d_vcache -name "amd_x3d_mode" -type f 2>/dev/null | head -1)

if [ -z "$X3D_MODE_PATH" ]; then
    exit 0
fi

case "${1}" in
    cache|frequency)
        current=$(cat "$X3D_MODE_PATH" 2>/dev/null)
        if [ "$current" = "$1" ]; then
            exit 0
        fi
        echo "$1" > "$X3D_MODE_PATH" 2>/dev/null || exit 1
        echo "X3D V-Cache mode: $current -> $1"
        ;;
    get|"")
        cat "$X3D_MODE_PATH"
        ;;
    *)
        echo "Usage: $(basename "$0") {cache|frequency|get}"
        exit 1
        ;;
esac
