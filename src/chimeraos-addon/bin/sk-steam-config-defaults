#!/usr/bin/env python3
"""Apply default Steam client settings before Steam starts.

- Enable developer mode and advanced update channels
  so that OS updates are shown separately from client updates.
- Disable wifi power management to avoid connectivity issues.
- Show battery percentage in the UI.
- Enable CEF remote debugging via Steam's marker file (Decky Loader, devtools).
"""

import glob
import json
import os
import sys

try:
    import vdf
except ImportError:
    vdf = None

STEAM_DIR = os.path.join(os.environ.get("HOME", ""), ".local/share/Steam")
STEAM_CONFIG = os.path.join(STEAM_DIR, "config/config.vdf")
CEF_REMOTE_DEBUGGING_MARKER = ".cef-enable-remote-debugging"

# --- config.vdf defaults ---
# path (str or tuple) -> { key: value }
# Paths are relative to the top-level VDF root (e.g. "InstallConfigStore").
CONFIG_DEFAULTS = {
    "developer": {
        "DevModeEnabled": "1",
        "ShowAdvancedUpdateChannels": "1",
    },
    ("Software", "Valve", "Steam", "System"): {
        "WifiPowerManagementEnabled": "0",
    },
}

# --- Per-user localconfig.vdf defaults ---
# path (str or tuple) -> { key: value }
# Paths are relative to the top-level VDF root (e.g. "UserLocalConfigStore").
# Values can be plain strings or dicts. Dict values are stored as JSON strings
# in the VDF file and will be merged (not replaced) with existing JSON content.
LOCALCONFIG_DEFAULTS = {
    "WebStorage": {
        "CachedBatteryPreferences": {"bShowBatteryPercentage": True},
    },
}


def ensure_cef_remote_debugging():
    """Create empty marker file(s) in the Steam root so CEF remote debugging is on."""
    home = os.environ.get("HOME", "")
    if not home:
        return
    try:
        os.makedirs(STEAM_DIR, mode=0o755, exist_ok=True)
        with open(os.path.join(STEAM_DIR, CEF_REMOTE_DEBUGGING_MARKER), "a"):
            pass
    except OSError:
        pass
    flatpak_steam = os.path.join(home, ".var/app/com.valvesoftware.Steam/data/Steam")
    if os.path.isdir(flatpak_steam):
        try:
            with open(os.path.join(flatpak_steam, CEF_REMOTE_DEBUGGING_MARKER), "a"):
                pass
        except OSError:
            pass


def resolve_path(root, path):
    """Walk into nested dicts by a tuple of keys, creating missing levels."""
    if isinstance(path, str):
        path = (path,)
    node = root
    for segment in path:
        if segment not in node:
            node[segment] = {}
        node = node[segment]
    return node


def apply_defaults(data, defaults):
    """Apply defaults to a parsed VDF dict. Returns True if anything changed."""
    root = data.get(next(iter(data), ""), {})
    if not isinstance(root, dict):
        return False

    changed = False
    for path, keys in defaults.items():
        section = resolve_path(root, path)
        for key, value in keys.items():
            if isinstance(value, dict):
                # JSON-encoded value: merge into existing JSON
                try:
                    existing = json.loads(section.get(key, "{}"))
                except (json.JSONDecodeError, TypeError):
                    existing = {}
                merged = {**existing, **value}
                new_val = json.dumps(merged, separators=(",", ":"))
                if section.get(key) != new_val:
                    section[key] = new_val
                    changed = True
            else:
                if section.get(key) != value:
                    section[key] = value
                    changed = True
    return changed


def apply_config_defaults():
    """Apply defaults to the global config.vdf."""
    if vdf is None or not os.path.isfile(STEAM_CONFIG):
        return

    with open(STEAM_CONFIG, "r", encoding="utf-8") as f:
        data = vdf.load(f)

    if apply_defaults(data, CONFIG_DEFAULTS):
        with open(STEAM_CONFIG, "w", encoding="utf-8") as f:
            vdf.dump(data, f, pretty=True)


def apply_localconfig_defaults():
    """Apply defaults to every user's localconfig.vdf."""
    if vdf is None:
        return
    pattern = os.path.join(STEAM_DIR, "userdata/*/config/localconfig.vdf")
    for path in glob.glob(pattern):
        try:
            with open(path, "r", encoding="utf-8") as f:
                data = vdf.load(f)
        except Exception:
            continue

        if apply_defaults(data, LOCALCONFIG_DEFAULTS):
            with open(path, "w", encoding="utf-8") as f:
                vdf.dump(data, f, pretty=True)


def main():
    ensure_cef_remote_debugging()
    apply_config_defaults()
    apply_localconfig_defaults()


if __name__ == "__main__":
    main()
